# OMEGA Configuration
# Copy this file to .env and fill in your values

# Required: Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: OpenRouter app identification (helps with rate limits/analytics)
OPENROUTER_SITE_URL=https://omega-agent.ai
OPENROUTER_APP_NAME=OMEGA Agent

# Optional: Redis for task queue (defaults to local redis if not set)
REDIS_URL=redis://localhost:6379/0

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Browser automation settings
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# Optional: API server settings
API_HOST=127.0.0.1
API_PORT=8888

# Optional: Sandbox settings
SANDBOX_ENABLED=true
DOCKER_SANDBOX_IMAGE=python:3.12-slim
